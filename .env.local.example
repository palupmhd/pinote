# Salin file ini jadi .env.local lalu isi dari Supabase:
# Project Settings → API
#
# Tanpa ini aplikasi tetap jalan penuh, hanya saja datanya cuma di perangkat ini.
# Kedua nilai ini memang aman ada di browser (anon key dibatasi oleh RLS di
# supabase/schema.sql) — tapi .env.local tetap tidak ikut ke git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
